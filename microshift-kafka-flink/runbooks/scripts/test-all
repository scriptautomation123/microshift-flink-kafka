#!/usr/bin/env bash

set -euo pipefail

export PATH="$HOME/.local/bin:$PATH"

usage() {
  cat <<'USAGE'
Usage:
  test-all [--clean] [--kafka-env <path>] [--flink-env <path>] [--kafka-topic <name>] [--skip-image-build] [--microshift-run-host-config] [--microshift-skip-local-pv] [--auto-ghcr] [--gh-owner <owner>] [--gh-user <user>] [--gh-pat <token>] [--skip-registry-login] [--flink-skip-sql-smoke]

Examples:
  docs/runbooks/scripts/test-all --clean \
    --kafka-env docs/kafka/openshift/env/dev.env \
    --flink-env docs/flink/openshift/env/dev.env \
    --kafka-topic ha-drill

  GH_OWNER=scriptautomation123 GH_USER=myuser GH_PAT=*** \
  docs/runbooks/scripts/test-all --clean --auto-ghcr

Options:
  --clean                  Full reset first (flink cleanup, kafka cleanup, microshift delete), then rebuild all.
  --kafka-env <path>       Kafka env file.
  --flink-env <path>       Flink env file.
  --kafka-topic <name>     Topic for Kafka maintenance assertions.
  --skip-image-build       Skip image builds in Kafka and Flink component tests.
  --microshift-run-host-config  Run microshift host config scripts (sudo operations).
  --microshift-skip-local-pv    Skip microshift local static PV provisioning helper.
  --auto-ghcr              Generate temporary GHCR-ready env files for kafka-dev/flink-dev.
  --gh-owner <owner>       GitHub owner/org for ghcr.io/<owner>. Defaults to GH_OWNER or git origin owner.
  --gh-user <user>         GitHub username for ghcr.io login and private image pull secret.
  --gh-pat <token>         GitHub PAT for ghcr.io login and private image pull secret.
  --skip-registry-login    Skip local container CLI registry login even when --auto-ghcr is used.
  --flink-skip-sql-smoke   Skip Flink SQL Gateway smoke test that writes/reads Kafka topics.
  -h, --help               Show help.
USAGE
}

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(cd "${SCRIPT_DIR}/../../.." && pwd)"

MICROSHIFT_TEST="${ROOT_DIR}/docs/microshift/scripts/test-all-functionality.sh"
KAFKA_TEST="${ROOT_DIR}/docs/kafka/openshift/scripts/test-all-functionality.sh"
FLINK_TEST="${ROOT_DIR}/docs/flink/openshift/scripts/test-all-functionality.sh"
NON_DESTRUCTIVE_VALIDATE="${ROOT_DIR}/docs/runbooks/scripts/validate-platform-all.sh"

KAFKA_ENV="${ROOT_DIR}/docs/kafka/openshift/env/dev.env"
FLINK_ENV="${ROOT_DIR}/docs/flink/openshift/env/dev.env"
KAFKA_TOPIC="ha-drill"
CLEAN=false
SKIP_IMAGE_BUILD=false
MICROSHIFT_RUN_HOST_CONFIG=false
MICROSHIFT_SKIP_LOCAL_PV=false
AUTO_GHCR=false
GH_OWNER_ARG=""
GH_USER_ARG=""
GH_PAT_ARG=""
SKIP_REGISTRY_LOGIN=false
FLINK_SKIP_SQL_SMOKE=false

GH_OWNER_RESOLVED=""
GH_USER_RESOLVED=""
GH_PAT_RESOLVED=""

WORK_KAFKA_ENV=""
WORK_FLINK_ENV=""

log() {
  printf '[%s] %s\n' "$(date +'%Y-%m-%dT%H:%M:%S%z')" "$*"
}

warn() {
  printf 'WARN: %s\n' "$*" >&2
}

require_file() {
  [[ -f "$1" ]] || { echo "ERROR: file not found: $1" >&2; exit 1; }
}

upsert_env() {
  local file="$1"
  local key="$2"
  local value="$3"
  if grep -qE "^${key}=" "${file}"; then
    sed -i "s|^${key}=.*$|${key}=${value}|" "${file}"
  else
    printf '%s=%s\n' "${key}" "${value}" >> "${file}"
  fi
}

namespace_from_env() {
  local env_file="$1"
  local ns
  ns=$(grep -E '^OPENSHIFT_NAMESPACE=' "${env_file}" | head -n1 | cut -d'=' -f2-)
  if [[ -n "${ns}" ]]; then
    printf '%s\n' "${ns}"
  fi
}

ensure_namespace() {
  local ns="$1"
  [[ -n "${ns}" ]] || return 1

  if ! oc get ns "${ns}" >/dev/null 2>&1; then
    log "Creating namespace ${ns}"
    oc create namespace "${ns}" >/dev/null
  fi

  log "Validating namespace ${ns}"
  oc get ns "${ns}" -o jsonpath='{.status.phase}' | grep -q '^Active$'
}

ensure_env_file() {
  local target="$1"
  local example="$2"
  if [[ ! -f "${target}" ]]; then
    log "env missing: ${target}; creating from ${example}"
    cp "${example}" "${target}"
  fi
}

detect_container_cli() {
  if command -v podman >/dev/null 2>&1; then
    printf 'podman\n'
    return 0
  fi
  if command -v docker >/dev/null 2>&1; then
    printf 'docker\n'
    return 0
  fi
  return 1
}

derive_owner_from_git() {
  local url owner
  url=$(git -C "${ROOT_DIR}" config --get remote.origin.url 2>/dev/null || true)
  if [[ -n "${url}" ]]; then
    owner=$(printf '%s' "${url}" | sed -E 's#.*github.com[:/]([^/]+)/.*#\1#')
    if [[ -n "${owner}" && "${owner}" != "${url}" ]]; then
      printf '%s\n' "${owner}"
      return 0
    fi
  fi
  return 1
}

resolve_ghcr_inputs() {
  GH_OWNER_RESOLVED="${GH_OWNER_ARG:-${GH_OWNER:-}}"
  GH_USER_RESOLVED="${GH_USER_ARG:-${GH_USER:-}}"
  GH_PAT_RESOLVED="${GH_PAT_ARG:-${GH_PAT:-}}"

  if [[ -z "${GH_OWNER_RESOLVED}" ]]; then
    GH_OWNER_RESOLVED=$(derive_owner_from_git || true)
  fi

  if [[ -z "${GH_OWNER_RESOLVED}" ]]; then
    echo "ERROR: GHCR owner is required for --auto-ghcr; set GH_OWNER or pass --gh-owner" >&2
    exit 1
  fi
}

ghcr_login_if_configured() {
  if [[ "${SKIP_REGISTRY_LOGIN}" == true ]]; then
    return 0
  fi

  if [[ -z "${GH_USER_RESOLVED}" || -z "${GH_PAT_RESOLVED}" ]]; then
    warn "GH user/token not provided; skipping local ghcr.io login"
    return 0
  fi

  local cli
  cli=$(detect_container_cli || true)
  if [[ -z "${cli}" ]]; then
    warn "no podman/docker found; skipping local ghcr.io login"
    return 0
  fi

  log "logging ${cli} into ghcr.io"
  printf '%s' "${GH_PAT_RESOLVED}" | "${cli}" login ghcr.io -u "${GH_USER_RESOLVED}" --password-stdin >/dev/null
}

cleanup_work_envs() {
  [[ -n "${WORK_KAFKA_ENV}" && -f "${WORK_KAFKA_ENV}" ]] && rm -f "${WORK_KAFKA_ENV}" || true
  [[ -n "${WORK_FLINK_ENV}" && -f "${WORK_FLINK_ENV}" ]] && rm -f "${WORK_FLINK_ENV}" || true
}

prepare_auto_ghcr_envs() {
  local kafka_source="$1"
  local flink_source="$2"

  resolve_ghcr_inputs

  WORK_KAFKA_ENV="$(mktemp)"
  WORK_FLINK_ENV="$(mktemp)"
  cp "${kafka_source}" "${WORK_KAFKA_ENV}"
  cp "${flink_source}" "${WORK_FLINK_ENV}"

  local kafka_cluster_id
  kafka_cluster_id="$(${ROOT_DIR}/docs/kafka/openshift/scripts/generate-kraft-cluster-id.sh)"
  kafka_cluster_id="$(printf '%s' "${kafka_cluster_id}" | tr -d '\r\n')"

  upsert_env "${WORK_KAFKA_ENV}" OPENSHIFT_NAMESPACE "kafka-dev"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_IMAGE "ghcr.io/${GH_OWNER_RESOLVED}/kafka-kraft:3.7.1"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_VERSION "3.7.1"
  upsert_env "${WORK_KAFKA_ENV}" SCALA_VERSION "2.13"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_CLUSTER_ID "${kafka_cluster_id}"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_REPLICAS "3"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_STORAGE_CLASS ""
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_STORAGE_SIZE "50Gi"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_DEFAULT_REPLICATION_FACTOR "3"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_MIN_INSYNC_REPLICAS "2"
  upsert_env "${WORK_KAFKA_ENV}" KAFKA_NUM_PARTITIONS "6"
  upsert_env "${WORK_KAFKA_ENV}" REGISTRY_PULL_SECRET_NAME "ghcr-pull"

  upsert_env "${WORK_FLINK_ENV}" OPENSHIFT_NAMESPACE "flink-dev"
  upsert_env "${WORK_FLINK_ENV}" FLINK_CLUSTER_ID "flink-sql-dev"
  upsert_env "${WORK_FLINK_ENV}" IMAGE_REGISTRY "ghcr.io/${GH_OWNER_RESOLVED}"
  upsert_env "${WORK_FLINK_ENV}" FLINK_IMAGE_TAG "2.3.0"
  upsert_env "${WORK_FLINK_ENV}" FLINK_VERSION "2.3.0"
  upsert_env "${WORK_FLINK_ENV}" SCALA_VERSION "2.12"
  upsert_env "${WORK_FLINK_ENV}" BASE_IMAGE_REF "\${IMAGE_REGISTRY}/\${OPENSHIFT_NAMESPACE}/flink-base:\${FLINK_IMAGE_TAG}"
  upsert_env "${WORK_FLINK_ENV}" SQL_RUNTIME_IMAGE_REF "\${IMAGE_REGISTRY}/\${OPENSHIFT_NAMESPACE}/flink-sql-runtime:\${FLINK_IMAGE_TAG}"
  upsert_env "${WORK_FLINK_ENV}" HA_STORAGE_URI "s3://replace-me/flink/ha"
  upsert_env "${WORK_FLINK_ENV}" CHECKPOINT_URI "s3://replace-me/flink/checkpoints"
  upsert_env "${WORK_FLINK_ENV}" SAVEPOINT_URI "s3://replace-me/flink/savepoints"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_BOOTSTRAP_SERVERS "kafka.kafka-dev.svc:9092"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_SOURCE_TOPIC "orders.raw"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_SINK_TOPIC "orders.curated"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_CONSUMER_GROUP "flink-orders-dev"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_SECURITY_PROTOCOL "PLAINTEXT"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_SASL_MECHANISM "PLAIN"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_SASL_JAAS_CONFIG "org.apache.kafka.common.security.plain.PlainLoginModule required username=\"unused\" password=\"unused\";"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_TRUSTSTORE_PASSWORD "dummy"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_TRUSTSTORE_FILE "/tmp/kafka.truststore.jks"
  upsert_env "${WORK_FLINK_ENV}" KAFKA_TRANSACTIONAL_ID_PREFIX "orders-curated-dev"
  upsert_env "${WORK_FLINK_ENV}" AWS_ACCESS_KEY_ID "replace-me"
  upsert_env "${WORK_FLINK_ENV}" AWS_SECRET_ACCESS_KEY "replace-me"
  upsert_env "${WORK_FLINK_ENV}" AWS_REGION "us-east-1"
  upsert_env "${WORK_FLINK_ENV}" PIPELINE_NAME "orders-curation-dev"
  upsert_env "${WORK_FLINK_ENV}" SQL_GATEWAY_BASE_URL "https://flink-sql-gateway-flink-dev.apps.example.com"
  upsert_env "${WORK_FLINK_ENV}" CONTAINER_CLI "podman"
  upsert_env "${WORK_FLINK_ENV}" REGISTRY_PULL_SECRET_NAME "ghcr-pull"

  if [[ -n "${GH_USER_RESOLVED}" ]]; then
    upsert_env "${WORK_KAFKA_ENV}" REGISTRY_LOGIN_USERNAME "${GH_USER_RESOLVED}"
    upsert_env "${WORK_FLINK_ENV}" REGISTRY_LOGIN_USERNAME "${GH_USER_RESOLVED}"
  fi
  if [[ -n "${GH_PAT_RESOLVED}" ]]; then
    upsert_env "${WORK_KAFKA_ENV}" REGISTRY_LOGIN_PASSWORD "${GH_PAT_RESOLVED}"
    upsert_env "${WORK_FLINK_ENV}" REGISTRY_LOGIN_PASSWORD "${GH_PAT_RESOLVED}"
  fi

  KAFKA_ENV="${WORK_KAFKA_ENV}"
  FLINK_ENV="${WORK_FLINK_ENV}"
  log "Auto GHCR env mode enabled using ghcr.io/${GH_OWNER_RESOLVED}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --clean)
      CLEAN=true
      shift
      ;;
    --kafka-env)
      KAFKA_ENV="${2:-}"
      shift 2
      ;;
    --flink-env)
      FLINK_ENV="${2:-}"
      shift 2
      ;;
    --kafka-topic)
      KAFKA_TOPIC="${2:-}"
      shift 2
      ;;
    --skip-image-build)
      SKIP_IMAGE_BUILD=true
      shift
      ;;
    --microshift-run-host-config)
      MICROSHIFT_RUN_HOST_CONFIG=true
      shift
      ;;
    --microshift-skip-local-pv)
      MICROSHIFT_SKIP_LOCAL_PV=true
      shift
      ;;
    --auto-ghcr)
      AUTO_GHCR=true
      shift
      ;;
    --gh-owner)
      GH_OWNER_ARG="${2:-}"
      shift 2
      ;;
    --gh-user)
      GH_USER_ARG="${2:-}"
      shift 2
      ;;
    --gh-pat)
      GH_PAT_ARG="${2:-}"
      shift 2
      ;;
    --skip-registry-login)
      SKIP_REGISTRY_LOGIN=true
      shift
      ;;
    --flink-skip-sql-smoke)
      FLINK_SKIP_SQL_SMOKE=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      usage
      exit 1
      ;;
  esac
done

if [[ "${KAFKA_ENV}" != /* ]]; then
  KAFKA_ENV="${ROOT_DIR}/${KAFKA_ENV}"
fi
if [[ "${FLINK_ENV}" != /* ]]; then
  FLINK_ENV="${ROOT_DIR}/${FLINK_ENV}"
fi

trap cleanup_work_envs EXIT

ensure_env_file "${KAFKA_ENV}" "${ROOT_DIR}/docs/kafka/openshift/env/example.env"
ensure_env_file "${FLINK_ENV}" "${ROOT_DIR}/docs/flink/openshift/env/example.env"

if [[ "${AUTO_GHCR}" == true ]]; then
  prepare_auto_ghcr_envs "${KAFKA_ENV}" "${FLINK_ENV}"
  ghcr_login_if_configured
fi

for f in "${MICROSHIFT_TEST}" "${KAFKA_TEST}" "${FLINK_TEST}" "${NON_DESTRUCTIVE_VALIDATE}"; do
  require_file "${f}"
  bash -n "${f}"
done

if [[ "${CLEAN}" == true ]]; then
  log "Running CLEAN phase: Flink cleanup, Kafka cleanup, then MicroShift cluster delete"
  FLINK_NS="$(namespace_from_env "${FLINK_ENV}")"
  KAFKA_NS="$(namespace_from_env "${KAFKA_ENV}")"

  if [[ -n "${FLINK_NS}" ]]; then
    log "Deleting Flink PVCs in namespace ${FLINK_NS}"
    oc delete pvc -n "${FLINK_NS}" --all --ignore-not-found || true
  fi
  if [[ -n "${KAFKA_NS}" ]]; then
    log "Deleting Kafka PVCs in namespace ${KAFKA_NS}"
    oc delete pvc -n "${KAFKA_NS}" --all --ignore-not-found || true
  fi

  "${FLINK_TEST}" --env "${FLINK_ENV}" --cleanup-only || true
  "${KAFKA_TEST}" --env "${KAFKA_ENV}" --cleanup-only || true
  "${MICROSHIFT_TEST}" --cleanup-only || true
fi

log "Running MicroShift full functionality"
microshift_args=()
if [[ "${MICROSHIFT_RUN_HOST_CONFIG}" == true ]]; then
  microshift_args+=(--run-host-config)
fi
if [[ "${MICROSHIFT_SKIP_LOCAL_PV}" == true ]]; then
  microshift_args+=(--skip-local-pv)
fi
"${MICROSHIFT_TEST}" "${microshift_args[@]}"

KAFKA_NS="$(namespace_from_env "${KAFKA_ENV}")"
FLINK_NS="$(namespace_from_env "${FLINK_ENV}")"

if [[ -z "${KAFKA_NS}" || -z "${FLINK_NS}" ]]; then
  echo "ERROR: failed to resolve Kafka or Flink namespace from env files" >&2
  exit 1
fi

log "Ensuring Kafka and Flink namespaces exist after MicroShift setup"
ensure_namespace "${KAFKA_NS}"
ensure_namespace "${FLINK_NS}"

log "Running Kafka full functionality"
kafka_args=(--env "${KAFKA_ENV}" --topic "${KAFKA_TOPIC}")
if [[ "${SKIP_IMAGE_BUILD}" == true ]]; then
  kafka_args+=(--skip-image-build)
fi
if [[ "${CLEAN}" == true ]]; then
  kafka_args+=(--clean)
fi
"${KAFKA_TEST}" "${kafka_args[@]}"

log "Running Flink full functionality"
flink_args=(--env "${FLINK_ENV}")
if [[ "${SKIP_IMAGE_BUILD}" == true ]]; then
  flink_args+=(--skip-build)
fi
if [[ "${CLEAN}" == true ]]; then
  flink_args+=(--clean)
fi
if [[ "${FLINK_SKIP_SQL_SMOKE}" == true ]]; then
  flink_args+=(--skip-sql-smoke)
fi
"${FLINK_TEST}" "${flink_args[@]}"

log "Running principal-engineer non-destructive validation"
"${NON_DESTRUCTIVE_VALIDATE}" \
  --kafka-env "${KAFKA_ENV}" \
  --flink-env "${FLINK_ENV}" \
  --kafka-topic "${KAFKA_TOPIC}" \
  --strict

log "ALL platform tests completed successfully"
