# Copy this file to env/<environment>.env and replace every placeholder.

OPENSHIFT_NAMESPACE=flink-prod
FLINK_CLUSTER_ID=flink-sql-prod

# For CI outside the cluster, point this at the pushable registry route.
IMAGE_REGISTRY=image-registry.openshift-image-registry.svc:5000
FLINK_IMAGE_TAG=2.3.0
FLINK_VERSION=2.3.0
SCALA_VERSION=2.12

BASE_IMAGE_REF=${IMAGE_REGISTRY}/${OPENSHIFT_NAMESPACE}/flink-base:${FLINK_IMAGE_TAG}
SQL_RUNTIME_IMAGE_REF=${IMAGE_REGISTRY}/${OPENSHIFT_NAMESPACE}/flink-sql-runtime:${FLINK_IMAGE_TAG}

HA_STORAGE_URI=s3://replace-me/flink/ha
CHECKPOINT_URI=s3://replace-me/flink/checkpoints
SAVEPOINT_URI=s3://replace-me/flink/savepoints

KAFKA_BOOTSTRAP_SERVERS=kafka-bootstrap.example.com:9093
KAFKA_SOURCE_TOPIC=orders.raw
KAFKA_SINK_TOPIC=orders.curated
KAFKA_CONSUMER_GROUP=flink-orders-prod
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-512
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.scram.ScramLoginModule required username="replace-me" password="replace-me";
KAFKA_TRUSTSTORE_PASSWORD=replace-me
KAFKA_TRUSTSTORE_FILE=/secure/path/kafka.truststore.jks
KAFKA_TRANSACTIONAL_ID_PREFIX=orders-curated-prod

AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1

PIPELINE_NAME=orders-curation-prod

SQL_GATEWAY_BASE_URL=https://flink-sql-gateway-flink-prod.apps.example.com

# Optional: set to podman or docker to avoid auto-detection.
CONTAINER_CLI=podman

# Optional: override if your CI cannot use the current `oc whoami` identity for registry login.
REGISTRY_LOGIN_USERNAME=
REGISTRY_LOGIN_PASSWORD=