OPENSHIFT_NAMESPACE=kafka-dev
KAFKA_NAMESPACE=kafka-dev

KAFKA_IMAGE=image-registry.openshift-image-registry.svc:5000/kafka-dev/kafka-kraft:3.7.1
ENVOY_IMAGE=envoyproxy/envoy:v1.31.0
KAFKA_CLUSTER_ID=replace-me-cluster-id

KAFKA_REPLICAS=3
KAFKA_STORAGE_SIZE=50Gi
KAFKA_DEFAULT_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_NUM_PARTITIONS=6
KAFKA_HEADLESS_SERVICE=kafka-headless
KAFKA_DATA_DIR=/var/lib/kafka/data

# External listener settings for the overlay
# NodePort mode: use nodePort values and stable broker DNS names.
# LoadBalancer mode: use the broker external VIP/DNS names and a stable port.
EXTERNAL_ACCESS_MODE=nodeport
KAFKA_EXTERNAL_LISTENER_NAME=EXTERNAL
KAFKA_EXTERNAL_LISTENER_INTERNAL_PORT=19093
KAFKA_EXTERNAL_SERVICE_PORT=19092

# One hostname per broker, in ordinal order.
KAFKA_EXTERNAL_BROKER_HOSTS=broker-0.example.com,broker-1.example.com,broker-2.example.com

# NodePort mode: one unique nodePort per broker.
KAFKA_EXTERNAL_BROKER_PORTS=31092,31093,31094

# LoadBalancer mode: the broker-external port advertised to clients.
KAFKA_EXTERNAL_LOADBALANCER_PORT=19092

# Optional registry creds if you later decide to publish a custom Kafka image.
REGISTRY_LOGIN_USERNAME=
REGISTRY_LOGIN_PASSWORD=
REGISTRY_PULL_SECRET_NAME=ghcr-pull
